{
	"name": "retold-data-mapper",
	"version": "0.0.1",
	"description": "Standalone service for cross-beacon schema mapping — runs its own Orator + Pict web UI on its own port, dispatches mesh operations via fable-ultravisor-client, registers DataMapper capabilities on any Ultravisor as a beacon.",
	"main": "source/Retold-DataMapper.js",
	"bin": {
		"retold-data-mapper": "bin/retold-data-mapper.js"
	},
	"scripts": {
		"start": "node bin/retold-data-mapper.js",
		"dev": "node test/dev-server.js",
		"interactive": "node test/harness/interactive.js",
		"seed": "node test/harness/seed-databases.js",
		"harness": "node test/harness/run-harness.js",
		"build": "npx quack build",
		"test": "npx quack test",
		"coverage": "npx quack coverage",
		"prepublishOnly": "npm test",
		"postversion": "npx quack release postversion",
		"postpublish": "npx quack release postpublish",
		"publish:docker": "npx quack release publish --image",
		"release:patch": "npx quack release patch",
		"release:minor": "npx quack release minor",
		"release:major": "npx quack release major",
		"release:patch:image": "npx quack release patch --image",
		"release:minor:image": "npx quack release minor --image",
		"release:major:image": "npx quack release major --image"
	},
	"mocha": {
		"spec": "test/DataMapper_tests.js",
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "30000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"lib/vendor"
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/stevenvelozo/retold-data-mapper.git"
	},
	"keywords": [
		"data",
		"mapper",
		"sync",
		"ultravisor",
		"beacon",
		"ETL"
	],
	"author": "Steven Velozo <steven@velozo.com> (http://velozo.com/)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/stevenvelozo/retold-data-mapper/issues"
	},
	"homepage": "https://github.com/stevenvelozo/retold-data-mapper",
	"devDependencies": {
		"better-sqlite3": "^12.9.0",
		"quackage": "^1.1.2"
	},
	"dependencies": {
		"fable": "^3.1.70",
		"fable-serviceproviderbase": "^3.0.19",
		"fable-ultravisor-client": "^0.0.1",
		"meadow": "^2.0.37",
		"meadow-connection-manager": "^1.0.2",
		"meadow-connection-sqlite": "^1.0.18",
		"meadow-endpoints": "^4.0.14",
		"meadow-integration": "^1.0.35",
		"orator": "^6.0.4",
		"orator-serviceserver-restify": "^2.0.10",
		"orator-static-server": "^2.0.4",
		"pict": "^1.0.364",
		"pict-application": "^1.0.33",
		"pict-view": "^1.0.68",
		"retold-databeacon": "^0.0.6",
		"ultravisor": "^1.0.23",
		"ultravisor-beacon": "^0.0.11"
	}
}
